# ═══════════════════════════════════════════════════════════════
# VoiceCraft Platform — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────
APP_NAME="VoiceCraft Platform"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# ── SECURITY — CHANGE THESE IN PRODUCTION ──────────────────────
SECRET_KEY=your-secret-key-min-32-chars-change-this-now
JWT_SECRET=your-jwt-secret-min-32-chars-change-this-now
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://voicecraft:voicecraft_pass@localhost:5432/voicecraft

# ── Redis / Celery ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── MinIO Object Storage ───────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=voicecraft_admin
MINIO_SECRET_KEY=voicecraft_secret_CHANGE_ME
MINIO_SECURE=false

# ── ML Models ──────────────────────────────────────────────────
MODELS_DIR=/app/models_cache
VOICE_PROFILES_DIR=/app/voice_profiles
TEMP_AUDIO_DIR=/tmp/voicecraft_audio

# Use "cuda" if you have an NVIDIA GPU (strongly recommended for speed)
XTTS_DEVICE=cpu
WHISPER_DEVICE=cpu
WHISPER_MODEL_SIZE=base

# ── CORS ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limits ────────────────────────────────────────────────
RATE_LIMIT_CLONE_PER_DAY=10
RATE_LIMIT_TTS_PER_DAY=500
RATE_LIMIT_DETECT_PER_DAY=1000
